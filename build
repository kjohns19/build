#!/usr/bin/env python3

import argparse
import json
import os.path
import time
import sys
from collections import OrderedDict

#TODO put in config file
DEFAULT_INFO = OrderedDict([
    ('projectname', 'example'),
    ('builddir', 'build.dir'),
    ('language', 'cpp'),
    ('cppflags', '-std=c++14 -g -Wall -Werror'),
    ('targets', [
        OrderedDict([
            ('name', 'example'),
            ('type', 'executable'),
            ('srcdirs', [ 'src' ])
        ])
    ])
])

# [ type, required, values ]
VALID_INFO = {
    'projectname': [ str, True ],
    'builddir': [ str, True ],
    'cppflags': [ str, False ],
    'cflags': [ str, False ],
    'libraries': [ [str], False ],
    'targets': [ [dict], True ],
}
VALID_TARGETS = {
    'name': [ str, True ],
    'type': [ str, False, ['executable', 'sharedlib', 'staticlib'] ],
    'srcs': [ [str], True ],
    'cppflags': [ str, False ],
    'cflags': [ str, False ],
    'libraries': [ [str], False ],
}

LIBRARYFILE = os.path.join(os.path.abspath(os.path.dirname(__file__)), '.build_libs')
with open(LIBRARYFILE) as config_file:
    LIBRARIES = json.load(config_file)
    keys = ['find_package', 'pkg_check', 'include_dirs', 'link_dirs', 'link_libs']
    for lib, data in LIBRARIES.items():
        data['name'] = lib
        for key in keys:
            data.setdefault(key, [])

def main():
    args = parse_args()
    info = read_info(args.file)
    if info['need_init']:
        generate_cmake(info)

def parse_args():
    parser = argparse.ArgumentParser()
    parser.add_argument(
        '-f', '--file', action='store',
        help='Use FILE as the build file')
    args = parser.parse_args()

    if args.file is None:
        args.file = 'build.info'

    return args

def validate(name, data, valid):
    missingRequired = []
    invalidTypes = []
    invalidValues = []
    for key, value in valid.items():
        valueType = value[0]
        if type(valueType) is list:
            listType = valueType[0]
            valueType = list
        required = value[1]
        if len(value) == 3:
            values = value[2]
        else:
            values = None
        if key in data:
            val = data[key]
            if type(val) is valueType:
                if type(val) is list:
                    for elem in val:
                        if type(elem) is not listType:
                            invalidTypes.append([key, [listType], type(elem)])
                if values is not None:
                    if val not in values:
                        invalidValues.append([key, values, val])
            else:
                invalidTypes.append([key, valueType, type(val)])
        elif required:
            missingRequired.append(key)
    if missingRequired or invalidTypes or invalidValues:
        print('ERROR: Invalid ' + name + ':')
        if missingRequired:
            print('    Missing required values: ' + ', '.join(missingRequired))
        for key, expected, actual in invalidTypes:
            if type(expected) is list:
                message = 'Invalid type in \'' + key + '\' list: '
                expected = expected[0]
            else:
                message = 'Invalid type for \'' + key + '\': '
            print('    ' + message +
                  'expected: ' + str(expected) + ', actual: ' + str(actual))
        for key, expected, actual in invalidValues:
            print('    Invalid value for \'' + key + '\': ' +
                  'expected one of [' + ', '.join(expected) + '], ' +
                  'actual: ' + actual)
        sys.exit(1)

def validate_info(info):
    validate('build info file', info, VALID_INFO)
    for count, target in enumerate(info['targets']):
        validate('target(' + str(count+1) + ')', target, VALID_TARGETS)

def read_info(filename):
    data = {}
    new_file = False
    if os.path.isfile(filename):
        with open(filename, 'r') as f:
            data['info'] = json.load(f)
        validate_info(data['info'])
    else:
        data['info'] = DEFAULT_INFO
        with open(filename, 'w') as f:
            json.dump(data['info'], f, indent=4)
        new_file = True

    build_dir = data['info']['builddir']
    cmake_file = os.path.join(build_dir, 'CMakeLists.txt')
    if not new_file and os.path.isfile(cmake_file):
        info_ts = time.ctime(os.path.getmtime(filename))
        cmake_ts = time.ctime(os.path.getmtime(cmake_file))
        data['need_init'] = (info_ts > cmake_ts)
    else:
        data['need_init'] = True

    return data

def generate_cmake(data):
    pass


if __name__ == '__main__':
    main()
