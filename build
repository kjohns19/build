#!/usr/bin/env python3.8

import argparse
import contextlib
import errno
import json
import jsonschema
import os
import pathlib
import shlex
import shutil
import subprocess
import sys

BUILDDATADIR = pathlib.Path(__file__).parent.resolve() / '.builddata'

TYPE_STRING = {'type': 'string'}
TYPE_STRING_ARRAY = {'type': 'array', 'items': TYPE_STRING}

SCHEMA_BUILD_INFO = {
    'type': 'object',
    'properties': {
        'projectname': TYPE_STRING,
        'builddir': TYPE_STRING,
        'flags': TYPE_STRING,
        'targets': {
            'type': 'array',
            'items': {
                'type': 'object',
                'properties': {
                    'name': TYPE_STRING,
                    'type': {
                        'type': 'string',
                        'pattern': 'executable|sharedlib|staticlib'
                    },
                    'srcs': TYPE_STRING_ARRAY,
                    'flags': TYPE_STRING,
                    'libraries': TYPE_STRING_ARRAY,
                    'include_dirs': TYPE_STRING_ARRAY,
                    'install_to': TYPE_STRING_ARRAY,
                    'install_includes': TYPE_STRING_ARRAY
                },
                'additionalProperties': False,
                'required': ['name', 'srcs']
            }
        }
    },
    'additionalProperties': False,
    'required': ['projectname', 'builddir', 'targets']
}

SCHEMA_LIBRARY = {
    'type': 'object',
    'properties': {
        'find_package': TYPE_STRING_ARRAY,
        'pkg_check': TYPE_STRING_ARRAY,
        'include_dirs': TYPE_STRING_ARRAY,
        'link_dirs': TYPE_STRING_ARRAY,
        'link_libs': TYPE_STRING_ARRAY
    },
    'additionalProperties': False,
    'required': ['link_libs']
}

CMAKEFILES = ['CMakeCache.txt', 'CMakeFiles', 'cmake_install.cmake', 'Makefile']

LIBRARIES = {}


def load_libraries_dir(directory):
    for libfilename in directory.iterdir():
        libraries = load_json(libfilename)
        for libname, libdata in libraries.items():
            try:
                jsonschema.validate(libdata, SCHEMA_LIBRARY)
            except Exception as e:
                print(f'Invalid library {libdata}: {e}')
                raise
            LIBRARIES[libname] = libdata


def load_libraries(info):
    librarydir = BUILDDATADIR / 'libs'
    load_libraries_dir(librarydir)
    locallibs = info.get('locallibs')
    if locallibs:
        load_libraries_dir(pathlib.Path(locallibs))


def main():
    args = parse_args()
    if args.listtemplates:
        print('Available templates: {", ".join(all_templates())}')
        return
    if args.projectname:
        copy_template(args.buildfile, args.projectname, args.template)
    data = read_info(args.buildfile)
    data['no_cmake'] = args.nocmake
    data['no_make'] = args.nomake
    data['run_cmake'] = False
    info = data['info']
    load_libraries(info)
    validate_info(info)
    is_git = is_git_repo()
    if not is_git and not args.nogit:
        init_git()
        is_git = True
    builddir = pathlib.Path(info['builddir'])
    builddir.mkdir(parents=True, exist_ok=True)
    check_source_files(data)
    if data['need_init']:
        generate_cmake(info, 'CMakeLists.txt')
        if is_git:
            generate_gitignore(info)
        data['run_cmake'] = True
    if data['run_cmake'] and not data['no_cmake']:
        run_cmake(builddir)
    if not data['no_make']:
        run_make(builddir, args.sudo, args.make_args)


def parse_args():
    desc = 'Easy to use wrapper script around cmake and make'
    parser = argparse.ArgumentParser(description=desc)
    parser.add_argument(
        '-f', '--buildfile', action='store', type=pathlib.Path,
        default=pathlib.Path('build.info'),
        help='Use FILE as the build file')
    parser.add_argument(
        '-i', '--init', action='store', dest='projectname',
        help='Initialize a new project build. This generates a new build.info file.')
    parser.add_argument(
        '-t', '--template', action='store',
        help='With -i/--init, use a template for initialization')
    parser.add_argument(
        '-T', '--listtemplates', action='store_true',
        help='List all available templates')
    parser.add_argument(
        '-c', '--nocmake', action='store_true',
        help='Don\'t run cmake')
    parser.add_argument(
        '-m', '--nomake', action='store_true',
        help='Don\'t run make')
    parser.add_argument(
        '-g', '--nogit', action='store_true',
        help='Don\'t create a git repository (with -i/--init)')
    parser.add_argument(
        '-s', '--sudo', action='store_true',
        help='Run make with sudo')
    parser.add_argument(
        'make_args', action='store', nargs='*',
        help='Pass argument to make')
    args = parser.parse_args()

    if args.projectname and not args.template:
        args.template = 'default'

    return args


def is_git_repo():
    command = ['git', 'rev-parse', '--git-dir']
    rc = subprocess.call(command, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
    return rc == 0


def load_json(filename):
    try:
        with open(filename, 'r') as f:
            return json.load(f)
    except ValueError as e:
        print(f'Failed to load data from {filename}: {e}', file=sys.stderr)
        sys.exit(1)


def copy_file(file, dest):
    try:
        shutil.copytree(file, dest)
    except OSError as e:
        if e.errno == errno.ENOTDIR:
            shutil.copy(file, dest)
        else:
            raise


def all_templates():
    all_template_dir = BUILDDATADIR / 'templates'
    return sorted(d.name for d in all_template_dir.iterdir() if d.is_dir())


def copy_template(buildfile, projectname, template):
    templatedir = BUILDDATADIR / 'templates' / template
    if not templatedir.is_dir():
        all_templates_str = ', '.join(all_templates)
        print(f'ERROR: Invalid template "{template}". '
              f'Valid templates: {all_templates_str}', file=sys.stderr)
        sys.exit(1)
    buildinfo = templatedir / 'build.info'
    if not buildinfo.is_file():
        print('ERROR: Invalid template "{template}". Missing build.info',
              file=sys.stderr)
        sys.exit(1)

    buildinfocontents = buildinfo.read_text()
    buildfile.write_text(buildinfocontents.replace('${project}', projectname) + '\n')

    for filename in [f for f in templatedir.iterdir() if f.name != 'build.info']:
        copy_file(filename, filename.name)


@contextlib.contextmanager
def move_cmake_files(srcdir, destdir):
    def do_move(srcdir, destdir):
        for file in CMAKEFILES:
            src = srcdir / file
            dest = destdir / file
            try:
                shutil.move(src, dest)
            except FileNotFoundError:
                pass

    do_move(srcdir, destdir)
    try:
        yield
    finally:
        do_move(destdir, srcdir)


def run_command(command):
    print(f'Running {shlex.join(command)}')
    return subprocess.call(command)


def init_git():
    command = ['git', 'init']
    run_command(command)


def generate_gitignore(info):
    print('Generating .gitignore')
    gitignore = [
        '#-- Generated by build --#',
        '# Build dir',
        '/build.dir',
        '',
        '# Vim swap files',
        '*.swp',
        '*.swo',
        '',
        '# Object files',
        '*.o',
        '',
        '# Libraries',
        '*.a',
        '*.so',
    ]
    executables = []
    has_install = False
    for target in info['targets']:
        if target['type'] == 'executable':
            executables.append(target['name'])
        if target.get('install_to'):
            has_install = True
    if has_install:
        gitignore.append('')
        gitignore.append('# Install manifest')
        gitignore.append('/install_manifest.txt')
    if executables:
        gitignore.append('')
        gitignore.append('# Executables')
        gitignore.append('\n'.join(['/' + exe for exe in executables]))

    endline = '#-- End generated by build --#'
    gitignore.append('')
    gitignore.append(endline)

    extra = []
    gitignorefile = pathlib.Path('.gitignore')
    if gitignorefile.is_file():
        extra = gitignorefile.read_text().split('\n')
        if endline in extra:
            extra = extra[extra.index(endline)+1:-1]

    gitignorefile.write_text('\n'.join(gitignore + extra) + '\n')


def run_cmake(builddir):
    with move_cmake_files(builddir, pathlib.Path.cwd()):
        command = ['cmake', '.']
        run_command(command)


def run_make(builddir, sudo, args):
    with move_cmake_files(builddir, pathlib.Path.cwd()):
        command = ['sudo'] if sudo else []
        command += ['make'] + args
        run_command(command)


def validate_info(info):
    try:
        jsonschema.validate(info, SCHEMA_BUILD_INFO)
    except Exception as e:
        print(f'Invalid build info: {e}')
        raise


def read_info(filename):
    data = {}
    if filename.is_file():
        data['info'] = load_json(filename)
    else:
        print(f'ERROR: build info file "{filename}" does not exist. '
              'Run "build --help" for help', file=sys.stderr)
        sys.exit(1)

    build_dir = data['info'].get('builddir')
    if build_dir:
        cmakefile = pathlib.Path('CMakeLists.txt')
        if cmakefile.is_file():
            info_ts = filename.stat().st_mtime
            cmake_ts = cmakefile.stat().st_mtime
            data['need_init'] = (info_ts > cmake_ts)
        else:
            data['need_init'] = True

    return data


def get_sources(pattern):
    if '*' not in pattern:
        return [pattern]
    pattern = pathlib.Path(pattern)
    filedir = pattern.parent
    filename = pattern.name
    command = ['find', str(filedir), '-name', filename]
    proc = subprocess.Popen(command, stdout=subprocess.PIPE, stderr=subprocess.DEVNULL)
    stdout, stderr = proc.communicate()
    return list(filter(None, stdout.decode('utf-8').split('\n')))


def check_source_files(data):
    info = data['info']
    srcdir = pathlib.Path(info['builddir']) / 'srcs'
    srcdir.mkdir(parents=True, exist_ok=True)
    all_srcs = {}
    for srcfile in srcdir.iterdir():
        all_srcs[srcfile.name] = [
            line for line in srcfile.read_text().split('\n') if line
        ]
        os.remove(srcfile)
    for target in info['targets']:
        name = target['name']
        srcs = [src for srcs in target['srcs'] for src in get_sources(srcs)]
        if not srcs:
            data['no_cmake'] = True
            data['no_make'] = True
        if name not in all_srcs or all_srcs[name] != srcs:
            data['run_cmake'] = True
        (srcdir / name).write_text('\n'.join(srcs) + '\n')


def unique_list(lst):
    seen = set()
    return [elem for elem in lst if not (elem in seen or seen.add(elem))]


def generate_cmake(info, filename):
    cmake_data = [
        'cmake_minimum_required(VERSION 2.8 FATAL_ERROR)',
        '',
        f'project({info["projectname"]})',
    ]

    print('Generating CMakeLists.txt')

    base_libraries = info.get('libraries', [])
    all_libraries = base_libraries.copy()
    target_libraries = {}
    for target in info['targets']:
        target_libs = target.get('libraries', [])
        all_libraries += target_libs
        libs = base_libraries + target_libs
        target_libraries[target['name']] = [LIBRARIES[lib] for lib in libs]
    lib_data = [LIBRARIES[lib] for lib in unique_list(all_libraries)]

    find_packs = sum([lib.get('find_package', []) for lib in lib_data], [])
    pkg_checks = sum([lib.get('pkg_check', []) for lib in lib_data], [])
    link_dirs = sum([lib.get('link_dirs', []) for lib in lib_data], [])

    if find_packs:
        cmake_data.append('')
        for pack in find_packs:
            cmake_data.append(f'find_package({pack})')

    if pkg_checks:
        cmake_data.append('')
        cmake_data.append('INCLUDE(FindPkgConfig)')
        cmake_data.append('')
        for pkg_check in pkg_checks:
            cmake_data.append(f'pkg_check_modules({pkg_check})')

    if link_dirs:
        cmake_data.append(f'link_directories({" ".join(link_dirs)})')

    install_libs = []

    install_types = set()

    for target in info['targets']:
        name = target['name']
        libs = target_libraries[name]
        cmake_data.append('')
        files_var = f'SRC_FILES_{name}'
        cmake_data.append(
            f'file(GLOB_RECURSE {files_var} {" ".join(target["srcs"])})')
        type_dict = {
            'executable': f'add_executable({name} ${{{files_var}}})',
            'sharedlib': f'add_library({name} SHARED ${{{files_var}}})',
            'staticlib': f'add_library({name} STATIC ${{{files_var}}})'
        }
        cmake_data.append(type_dict[target['type']])
        flags = ' '.join((info.get('flags', ''), target.get('flags', ''))).strip()
        if flags:
            options = f'{name} PRIVATE {flags}'
            cmake_data.append(f'target_compile_options({options})')

        include_dirs = sum([lib.get('include_dirs', []) for lib in libs], [])
        include_dirs += info.get('include_dirs', []) + target.get('include_dirs', [])
        if include_dirs:
            dirs = ' '.join(include_dirs)
            cmake_data.append(
                f'target_include_directories({name} PRIVATE {dirs})')

        link_libs = sum([lib['link_libs'] for lib in libs], [])
        if link_libs:
            links = ' '.join(link_libs)
            cmake_data.append(f'target_link_libraries({name} {links})')

    include_files = []
    include_patterns = []

    install_types = {
        'executable': 'RUNTIME',
        'sharedlib': 'LIBRARY',
        'staticlib': 'ARCHIVE'
    }

    cmake_data.append('')

    for target in info['targets']:
        name = target['name']
        install_type = install_types[target['type']]
        for dest in target.get('install_to', []):
            cmake_data.append(
                f'install(TARGETS {name} {install_type} DESTINATION {dest})')

        for include in target.get('install_includes', []):
            if '*' in include:
                include_path = pathlib.Path(include)
                srcdir = include_path.parent
                pattern = include_path.name
                include_patterns.append([str(srcdir), pattern])
            else:
                include_files.append(include)
        if target['type'] in ('sharedlib', 'staticlib') and target.get('install'):
            install_libs.append(name)
            install_types.add(target['type'])

    if install_libs:
        cmake_data.append(
            f'install(TARGETS {" ".join(install_libs)} ARCHIVE DESTINATION lib')

    if include_files:
        files = ' '.join(include_files)
        cmake_data.append(f'install(FILES {files} DESTINATION include)')
    for include_pattern in include_patterns:
        srcdir = include_pattern[0] + '/'
        pattern = include_pattern[1]
        cmake_data.append(f'install(DIRECTORY {srcdir} DESTINATION '
                          f'include FILES_MATCHING PATTERN "{pattern}")')

    for copy in info.get('copy', []):
        cmake_data.append(copy)

    builddir = pathlib.Path(info['builddir'])
    with move_cmake_files(pathlib.Path.cwd(), builddir):
        with open(filename, 'w') as f:
            print('\n'.join(cmake_data), file=f)


if __name__ == '__main__':
    try:
        main()
    except KeyboardInterrupt:
        print('build: Interrupt')
