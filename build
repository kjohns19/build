#!/usr/bin/env python3

import argparse
import json
import os.path
import time
import sys
import glob
from collections import OrderedDict

#TODO put in config file
DEFAULT_INFO = OrderedDict([
    ('projectname', 'example'),
    ('builddir', 'build.dir'),
    ('flags', '-std=c++14 -g -Wall -Werror'),
    ('include_dirs', [ 'src' ]),
    ('targets', [
        OrderedDict([
            ('name', 'program'),
            ('type', 'executable'),
            ('srcs', [ 'src/*.cpp' ])
        ])
    ])
])

# [ type, required, default, values ]
VALID_INFO = {
    'projectname': [ str, True ],
    'builddir': [ str, True ],
    'flags': [ str, False, '' ],
    'libraries': [ [str], False, [] ],
    'targets': [ [dict], True ],
    'include_dirs': [ [str], False, [] ],
}
VALID_TARGETS = {
    'name': [ str, True ],
    'type': [ str, False, 'executable', ['executable', 'sharedlib', 'staticlib'] ],
    'srcs': [ [str], True ],
    'flags': [ str, False, '' ],
    'libraries': [ [str], False, [] ],
    'include_dirs': [ [str], False, [] ],
}
VALID_LIBRARIES = {
    'find_package': [ [str], False, [] ],
    'pkg_check':    [ [str], False, [] ],
    'include_dirs': [ [str], False, [] ],
    'link_dirs':    [ [str], False, [] ],
    'link_libs':    [ [str], True ],
}

LIBRARIES = {}
def load_libraries_dir(directory):
    for libfilename in glob.glob(os.path.join(directory, '*')):
        with open(libfilename) as libfile:
            libraries = json.load(libfile)
            for libname, libdata in libraries.items():
                validate('library ' + libname, libdata, VALID_LIBRARIES)
                LIBRARIES[libname] = libdata
def load_libraries(info):
    librarydir = os.path.join(os.path.abspath(os.path.dirname(__file__)), '.build_libs')
    builddir = info.get('builddir') or DEFAULT_INFO['builddir']
    buildlibdir = os.path.join(builddir, 'libs')
    load_libraries_dir(librarydir)
    load_libraries_dir(buildlibdir)
    librarynames = list(LIBRARIES.keys())
    VALID_INFO['libraries'].append(librarynames)
    VALID_TARGETS['libraries'].append(librarynames)

def main():
    args = parse_args()
    info = read_info(args.file)
    load_libraries(info['info'])
    validate_info(info['info'])
    if info['need_init']:
        generate_cmake(info)

def parse_args():
    parser = argparse.ArgumentParser()
    parser.add_argument(
        '-f', '--file', action='store',
        help='Use FILE as the build file')
    args = parser.parse_args()

    if args.file is None:
        args.file = 'build.info'

    return args

def validate(name, data, valid):
    missingRequired = []
    invalidTypes = []
    invalidValues = []
    for key, value in valid.items():
        valueType = value[0]
        if type(valueType) is list:
            listType = valueType[0]
            valueType = list
        required = value[1]
        default = value[2] if len(value) > 2 else None
        values  = value[3] if len(value) > 3 else None
        if key in data:
            val = data[key]
            if isinstance(val, valueType):
                if valueType is list:
                    for elem in val:
                        if not isinstance(elem, listType):
                            invalidTypes.append([key, [listType], type(elem)])
                if values is not None:
                    if isinstance(val, list):
                        vals = val
                    else:
                        vals = [val]
                    for val in vals:
                        if val not in values:
                            invalidValues.append([key, values, val])
            else:
                invalidTypes.append([key, valueType, type(val)])
        elif required:
            missingRequired.append(key)
        else:
            data[key] = default
    if missingRequired or invalidTypes or invalidValues:
        print('ERROR: Invalid ' + name + ':')
        if missingRequired:
            print('    Missing required values: ' + ', '.join(missingRequired))
        for key, expected, actual in invalidTypes:
            if isinstance(expected, list):
                message = 'Invalid type in \'' + key + '\' list: '
                expected = expected[0]
            else:
                message = 'Invalid type for \'' + key + '\': '
            print('    ' + message +
                  'expected: ' + str(expected) + ', actual: ' + str(actual))
        for key, expected, actual in invalidValues:
            print('    Invalid value for \'' + key + '\': ' +
                  'expected one of [' + ', '.join(expected) + '], ' +
                  'actual: ' + actual)
        sys.exit(1)

def validate_info(info):
    validate('build info file', info, VALID_INFO)
    for count, target in enumerate(info['targets']):
        validate('target(' + str(count+1) + ')', target, VALID_TARGETS)

def read_info(filename):
    data = {}
    new_file = False
    if os.path.isfile(filename):
        with open(filename, 'r') as f:
            data['info'] = json.load(f)
    else:
        data['info'] = DEFAULT_INFO
        with open(filename, 'w') as f:
            json.dump(data['info'], f, indent=4)
        new_file = True

    build_dir = data['info'].get('builddir') or DEFAULT_INFO['builddir']
    cmake_file = os.path.join(build_dir, 'CMakeLists.txt')
    if not new_file and os.path.isfile(cmake_file):
        info_ts = time.ctime(os.path.getmtime(filename))
        cmake_ts = time.ctime(os.path.getmtime(cmake_file))
        data['need_init'] = (info_ts > cmake_ts)
    else:
        data['need_init'] = True

    return data

def generate_cmake(data):
    info = data['info']

    cmake_data = [
        'cmake_minimum_required(VERSION 2.8 FATAL_ERROR)',
        '',
        'project(' + info['projectname'] + ')',
    ]

    base_libraries = set(info['libraries'])
    all_libraries = set(base_libraries)
    target_libraries = {}
    for target in info['targets']:
        target_libs = set(target['libraries'])
        all_libraries |= target_libs
        libs = base_libraries | target_libs
        target_libraries[target['name']] = [LIBRARIES[l] for l in libs]
    lib_data = [LIBRARIES[lib] for lib in all_libraries]

    find_packs = sum([lib['find_package'] for lib in lib_data], [])
    pkg_checks = sum([lib['pkg_check']    for lib in lib_data], [])
    link_dirs  = sum([lib['link_dirs']    for lib in lib_data], [])
    
    if find_packs:
        cmake_data.append('')
        for pack in find_packs:
            cmake_data.append('find_package(' + pack + ')')

    if pkg_checks:
        cmake_data.append('')
        cmake_data.append('INCLUDE(FindPkgConfig)')
        cmake_data.append('')
        for pkg_check in pkg_checks:
            cmake_data.append('pkg_check_modules(' + pkg_check + ')')

    if link_dirs:
        cmake_data.append('link_directories(' + ' '.join(link_dirs) + ')')

    for target in info['targets']:
        name = target['name']
        libs = target_libraries[name]
        cmake_data.append('')
        files_var = 'SRC_FILES_' + name
        cmake_data.append(
            'file(GLOB ' + files_var + ' ' + ' '.join(target['srcs']) + ')')
        type_dict = {
            'executable': 'add_executable(' + name + ' ${' + files_var + '})',
            'sharedlib': 'add_library(' + name + ' SHARED ${' + files_var + '})',
            'staticlib': 'add_library(' + name + ' STATIC ${' + files_var + '})'
        }
        cmake_data.append(type_dict[target['type']])
        flags = (info['flags'] + ' ' + target['flags']).strip()
        if flags:
            options = name + ' PRIVATE ' + flags
            cmake_data.append('target_compile_options(' + options + ')')

        include_dirs = sum([lib['include_dirs'] for lib in libs], [])
        include_dirs += info['include_dirs'] + target['include_dirs']
        if include_dirs:
            dirs = ' '.join(include_dirs)
            cmake_data.append(
                'target_include_directories(' + name + ' PRIVATE ' + dirs + ')')

        link_libs    = sum([lib['link_libs']    for lib in libs], [])
        if link_libs:
            links = ' '.join(link_libs)
            cmake_data.append('target_link_libraries(' + name + ' ' + links + ')')

    print('\n'.join(cmake_data))


if __name__ == '__main__':
    main()
